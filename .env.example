# ── Required ──────────────────────────────────────────────────────────────────
SNAPCAST_HOST=192.168.x.x

# ── Container identity ────────────────────────────────────────────────────────
# Must match container_name in docker-compose.yml — used by the Update Now endpoint.
CONTAINER_NAME=jartcentre-agent
IMAGE_NAME=ghcr.io/tom-bass/jartcentre-agent:latest
GITHUB_REPO=Tom-bass/jartcentre-agent

# ── Disk reporting ────────────────────────────────────────────────────────────
# Report host filesystem usage rather than the container's overlay filesystem.
DISK_ROOT=/hostfs

# ── Security ──────────────────────────────────────────────────────────────────
# Restricts /metrics, /docker/*, and /system/reboot to callers presenting this key
# in an X-API-Key header. Recommended for any deployment reachable beyond localhost.
# Generate a key: openssl rand -hex 32
# AGENT_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# GitHub personal access token — avoids the 60 req/hr unauthenticated rate limit
# when the Update Now button checks for a newer image. read:packages scope is enough.
# GITHUB_TOKEN=

# Override the display name shown in Snapcast and the Spotify app.
# Defaults to the Pi's hostname.
# DEVICE_NAME=living-room-pi

# Force a specific ALSA output device (overrides the web UI selection).
# Find device names with: docker exec jartcentre-agent aplay -l
# LIBRESPOT_DEVICE=plughw:Device,0
